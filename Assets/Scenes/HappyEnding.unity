  dialogues:
  - speakerName: "\uC720\uB098"
    dialogue: "...\uC654\uAD6C\uB098"
    speakerSide: 1
  - speakerName: "\uC720\uB098"
    dialogue: "\uC815\uB9D0 \uC5EC\uAE30\uAE4C\uC9C0 \uC640\uC92C\uB124."
    speakerSide: 1
  - speakerName: "\uC720\uB098"
    dialogue: "\uACC4\uC18D \uAE30\uB2E4\uB838\uC5B4."
    speakerSide: 1
  - speakerName: "\uC720\uB098"
    dialogue: "\uD639\uC2DC \uC624\uC9C0 \uC54A\uC73C\uBA74 \uC5B4\uB5A1\uD558\uC9C0."
    speakerSide: 1
  - speakerName: "\uC720\uB098"
    dialogue: "\uC624\uB294 \uAE38\uC5D0 \uD3EC\uAE30\uD558\uBA74 \uC5B4\uB5A1\uD558\uC9C0."
    speakerSide: 1
  - speakerName: "\uC720\uB098"
    dialogue: "\uADF8\uB7F0 \uC0DD\uAC01\uB9CC \uACC4\uC18D \uD588\uC5B4."
    speakerSide: 1
  - speakerName: "\uC720\uB098"
    dialogue: "\uADF8\uB798\uC11C \uB108\uB97C \uC7AC\uCD09\uD558\uACE0,"
    speakerSide: 1
  - speakerName: "\uC720\uB098"
    dialogue: "\uC870\uAE08 \uC2EC\uD55C \uB9D0\uB3C4 \uD588\uB358 \uAC83 \uAC19\uC544."
    speakerSide: 1
  - speakerName: "\uC720\uB098"
    dialogue: "\uBBF8\uC548\uD574."
    speakerSide: 1
  - speakerName: "\uC720\uB098"
    dialogue: "\uADF8\uB798\uB3C4 \uB124\uAC00 \uC774\uB807\uAC8C \uBB34\uC0AC\uD788
      \uC640\uC918\uC11C \uB2E4\uD589\uC774\uC57C."
    speakerSide: 1
  - speakerName: "\uC720\uB098"
    dialogue: "\u2026\u2026\uC870\uAE08\uB9CC \uAC00\uAE4C\uC774 \uC640\uC904\uB798?"
    speakerSide: 1
  - speakerName: "\uC720\uB098"
    dialogue: "\uB124\uAC00 \uC815\uB9D0 \uC5EC\uAE30 \uC788\uB2E4\uB294 \uAC78 \uD655\uC778\uD558\uACE0
      \uC2F6\uC5B4."
    speakerSide: 1
