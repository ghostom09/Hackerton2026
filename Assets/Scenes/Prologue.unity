  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::PrologueDialogueController
  senderName: "\uC720\uB098"
  dialogueLines:
  - message: "\uB0B4 \uBB38\uC790 \uBCF4\uC5EC?"
  - message: "\uC9C0\uAE08 \uB098\uB294 \uC774\uACF3\uC5D0 \uAC07\uD600 \uC788\uC5B4."
  - message: "\uC624\uB294 \uAE38\uC5D0\uB294 \uBA87 \uAC00\uC9C0 \uBB38\uC81C\uAC00
      \uC788\uC744 \uAC70\uC57C."
  - message: "\uC5B4\uB835\uC9C0\uB294 \uC54A\uC744 \uD14C\uB2C8\uAE4C \uCE68\uCC29\uD558\uAC8C
      \uD574\uACB0\uD558\uBA74\uC11C \uC640\uC918."
  - message: "\uADF8\uB9AC\uACE0 \uB108\uBB34 \uC11C\uB450\uB974\uC9C0\uB294 \uB9C8."
  - message: "\uB124\uAC00 \uB2E4\uCE58\uBA74 \uACE4\uB780\uD558\uB2C8\uAE4C."
  - message: "\u2026\u2026\uADF8\uB798\uB3C4 \uBA48\uCDB0 \uC788\uC9C0\uB294 \uB9D0\uACE0."
  - message: "\uACC4\uC18D \uAE30\uB2E4\uB9AC\uB294 \uAC74 \uC870\uAE08 \uBB34\uC12D\uAC70\uB4E0."
  - message: "\uD639\uC2DC \uB124\uAC00 \uC911\uAC04\uC5D0 \uD3EC\uAE30\uD558\uBA74
      \uC5B4\uB5A1\uD558\uC9C0."
  - message: "\uB098\uB97C \uC78A\uC5B4\uBC84\uB9AC\uBA74 \uC5B4\uB5A1\uD558\uC9C0."
  - message: "\uADF8\uB7F0 \uC0DD\uAC01\uC774 \uC790\uAFB8 \uB4E4\uC5B4."
  - message: "\uD558\uC9C0\uB9CC \uB10C \uC640\uC904 \uAC70\uC9C0?"
  - message: "\uC5EC\uAE30\uAE4C\uC9C0 \uB110 \uAE30\uB2E4\uB9B0 \uB098\uB97C \uD63C\uC790
      \uB450\uC9C0\uB294 \uC54A\uC744 \uAC70\uC796\uC544."
  - message: "\uADF8\uB7EC\uB2C8\uAE4C \uB0A0 \uAD6C\uD558\uB7EC \uC640\uC918."
  - message: "\uADF8\uAC83\uB9CC\uC73C\uB85C \uCDA9\uBD84\uD574."
  - message: "\u2026\u2026\uC544\uB9C8\uB3C4."
  - message: "\uB098\uB294 \uC5EC\uAE30\uC11C \uAE30\uB2E4\uB9AC\uACE0 \uC788\uC744\uAC8C."
  - message: "\uADF8\uB7EC\uB2C8\uAE4C \uB108\uBB34 \uB2A6\uC9C0\uB294 \uB9C8."
  openingFadeDuration: 0.6
  chatOpenDelay: 0.3
  firstMessageDelay: 0.7
  lastMessageHoldDuration: 0.85
  messageScrollSensitivity: 120
  canvas: {fileID: 1935291122}
  chatPanel: {fileID: 1878044638}
  chatTitleText: {fileID: 436275693}
